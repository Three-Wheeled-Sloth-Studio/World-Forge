{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "../../.local/types/packages/shared",
    "emitDeclarationOnly": true,
    "tsBuildInfoFile": "../../.local/tsbuildinfo/packages-shared.tsbuildinfo",
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
