{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "../../.local/types/packages/renderer",
    "emitDeclarationOnly": true,
    "tsBuildInfoFile": "../../.local/tsbuildinfo/packages-renderer.tsbuildinfo",
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "baseUrl": "../..",
    "paths": {
      "@world-forge/shared": ["packages/shared/src/index.ts"]
    }
  },
  "references": [{ "path": "../shared" }],
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
