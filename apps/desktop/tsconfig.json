{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "../../.local/types/apps/desktop",
    "emitDeclarationOnly": true,
    "tsBuildInfoFile": "../../.local/tsbuildinfo/apps-desktop.tsbuildinfo",
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "baseUrl": "../..",
    "paths": {
      "@world-forge/shared": ["packages/shared/src/index.ts"],
      "@world-forge/shared/*": ["packages/shared/src/*"],
      "@world-forge/generator-core": ["packages/generator-core/src/index.ts"],
      "@world-forge/generator-core/*": ["packages/generator-core/src/*"],
      "@world-forge/generation-runtime": ["packages/generation-runtime/src/index.ts"],
      "@world-forge/generation-runtime/*": ["packages/generation-runtime/src/*"],
      "@world-forge/renderer": ["packages/renderer/src/index.ts"],
      "@world-forge/exporters": ["packages/exporters/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/generator-core" },
    { "path": "../../packages/generation-runtime" },
    { "path": "../../packages/renderer" },
    { "path": "../../packages/exporters" }
  ],
  "include": ["src"]
}
